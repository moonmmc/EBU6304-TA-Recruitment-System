<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Applications - BUPT TA Recruitment</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
  <aside class="sidebar">
    <a class="sidebar-brand" href="/ta/dashboard.html"><div class="sb-icon">TA</div><span>TA Recruitment</span></a>
    <div class="sidebar-nav" role="navigation" aria-label="Main navigation">
      <div class="sidebar-section">Main</div>
      <a class="sidebar-item" href="/ta/dashboard.html"><span class="si-icon">📊</span>Dashboard</a>
      <a class="sidebar-item" href="/ta/profile.html"><span class="si-icon">👤</span>My Profile</a>
      <div class="sidebar-section">Recruitment</div>
      <a class="sidebar-item" href="/ta/positions.html"><span class="si-icon">💼</span>Browse Positions</a>
      <a class="sidebar-item active" href="/ta/applications.html"><span class="si-icon">📋</span>My Applications</a>
    </div>
    <div class="sidebar-user"><div class="sidebar-avatar">?</div><div><div style="font-weight:600;font-size:13px">Guest</div><div style="font-size:11px;color:rgba(255,255,255,0.4)">TA</div></div></div>
  </aside>
  <main class="main-content">
    <div class="main-top">
      <div>
        <h2>My Applications</h2>
        <div class="mt-desc">Track the status of your TA applications</div>
      </div>
    </div>

    <div class="tabs">
      <button class="tab active" data-filter="ALL" onclick="setFilter('ALL', this)">All</button>
      <button class="tab" data-filter="PENDING" onclick="setFilter('PENDING', this)">Pending</button>
      <button class="tab" data-filter="PASSED" onclick="setFilter('PASSED', this)">Passed</button>
      <button class="tab" data-filter="FAILED" onclick="setFilter('FAILED', this)">Failed</button>
    </div>

    <div class="table-wrapper">
      <table>
        <thead><tr><th>Position</th><th>Course</th><th>Applied Date</th><th>Status</th><th>Feedback</th></tr></thead>
        <tbody id="appBody"></tbody>
      </table>
    </div>
  </main>
</div>

<script src="/js/app.js"></script>
<script>
let allApps = [];
let currentFilter = 'ALL';
bootstrapPage('TA', init, 'applications');

async function init() {
  allApps = await api('/applications?taId=' + user.id);
  renderApps();
}

function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  renderApps();
}

function renderApps() {
  const filtered = currentFilter === 'ALL' ? allApps : allApps.filter(a => a.status === currentFilter);
  const body = document.getElementById('appBody');
  if (filtered.length === 0) {
    body.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--gray-400)">No applications found</td></tr>';
    return;
  }
  body.innerHTML = filtered.map(a => `
    <tr>
      <td><strong>${escapeHtml(a.positionTitle)}</strong></td>
      <td>${a.courseCode}</td>
      <td>${formatDate(a.appliedDate)}</td>
      <td><span class="badge ${badgeClass(a.status)}">${a.status}</span></td>
      <td style="font-size:12px;color:var(--gray-500)">${escapeHtml(a.feedback)}</td>
    </tr>`).join('');
}
</script>
</body>
</html>
